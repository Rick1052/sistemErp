# Copie para .env e preencha os valores

# URL do pooler (opcional em dev). Em produção com Supabase, use DIRECT_URL no app.
DATABASE_URL=
# Conexão direta (porta 5432) — obrigatória no Railway para transações Prisma
DIRECT_URL=
JWT_SECRET=
JWT_REFRESH_SECRET=
PORT=3000

# Origens permitidas no CORS (separadas por vírgula)
# Produção Cerâmica Marim:
ALLOWED_ORIGINS=https://erp.ceramicamm.com.br,https://www.erp.ceramicamm.com.br

# NODE_ENV=production
