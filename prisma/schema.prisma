generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Status {
  ACTIVE
  INACTIVE
}

enum StockAction {
  NONE
  RESERVE
  COMMIT
}

enum Role {
  ADMIN
  USER
}

enum ClientType {
  PF
  PJ
  PE
}

enum MovementType {
  IN
  OUT
  BALANCE
  RESERVE
  RELEASE_RESERVE
}

enum FinancialRecordType {
  PAYABLE
  RECEIVABLE
}

enum FinancialStatus {
  PENDING
  PAID
  CANCELLED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum CategoryType {
  REVENUE
  EXPENSE
}

//////////////////////////////////////////////////////
// USER & AUTH
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies      UserCompany[]
  refreshTokens  RefreshToken[]
  stockMovements StockMovement[]
}

model Company {
  id        String   @id @default(uuid())
  cod       Int      @unique
  name      String
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sequence CompanySequence?

  users          UserCompany[]
  clients        Client[]
  suppliers      Supplier[]
  brands         Brand[]
  categories     Category[]
  tags           Tag[]
  products       Product[]
  warehouses     Warehouse[]
  inventories    ProductInventory[]
  taxes          ProductTax[]
  stockMovements StockMovement[]
  sales          Sale[]
  saleStatuses   SaleStatus[]

  bankAccounts        BankAccount[]
  paymentMethods      PaymentMethod[]
  financialCategories FinancialCategory[]
  financialRecords    FinancialRecord[]
}

model CompanySequence {
  companyId String  @id
  company   Company @relation(fields: [companyId], references: [id])

  clientSeq        Int @default(0)
  supplierSeq      Int @default(0)
  brandSeq         Int @default(0)
  categorySeq      Int @default(0)
  tagSeq           Int @default(0)
  warehouseSeq     Int @default(0)
  productSeq       Int @default(0)
  productTaxSeq    Int @default(0)
  inventorySeq     Int @default(0)
  stockMovementSeq Int @default(0)
  saleSeq          Int @default(0)
  saleItemSeq      Int @default(0)
  saleStatusSeq    Int @default(0)

  accountSeq           Int @default(0)
  paymentMethodSeq     Int @default(0)
  financialCategorySeq Int @default(0)
  financialRecordSeq   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserCompany {
  userId    String
  companyId String
  role      Role   @default(ADMIN)

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@id([userId, companyId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// CLIENT
//////////////////////////////////////////////////////

model Client {
  id       String     @id @default(uuid())
  cod      Int
  name     String
  type     ClientType
  document String
  status   Status     @default(ACTIVE)

  ie          String?
  indicatorIE Int?

  email String?
  phone String?

  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  country      String  @default("1058")

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales Sale[]

  @@unique([companyId, cod])
  @@unique([companyId, document])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// SUPPLIER
//////////////////////////////////////////////////////

model Supplier {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name     String
  document String?
  email    String?
  phone    String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// BRAND
//////////////////////////////////////////////////////

model Brand {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name     String
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// CATEGORY
//////////////////////////////////////////////////////

model Category {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name String

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// TAG
//////////////////////////////////////////////////////

model Tag {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name String

  products Product[] @relation("ProductTags")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// WAREHOUSE
//////////////////////////////////////////////////////

model Warehouse {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name     String
  location String?

  inventories    ProductInventory[]
  stockMovements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// PRODUCT
//////////////////////////////////////////////////////

model Product {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code             String?
  description      String
  shortDescription String?
  status           Status  @default(ACTIVE)

  price         Decimal  @db.Decimal(15, 2)
  costPrice     Decimal? @db.Decimal(15, 2)
  averageCost   Decimal  @default(0) @db.Decimal(15, 2)

  physicalStock Int      @default(0)
  reservedStock Int      @default(0)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  tags Tag[] @relation("ProductTags")

  inventories    ProductInventory[]
  stockMovements StockMovement[]
  tax            ProductTax?

  weight Decimal? @db.Decimal(15, 3)
  width  Decimal? @db.Decimal(15, 2)
  height Decimal? @db.Decimal(15, 2)
  depth  Decimal? @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItems SaleItem[]

  @@unique([companyId, cod])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// PRODUCT TAX
//////////////////////////////////////////////////////

model ProductTax {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  productId String  @unique
  product   Product @relation(fields: [productId], references: [id])

  origin      String?
  ncm         String?
  cest        String?
  gtin        String?
  ipiTaxClass String?

  icmsStBase    Decimal? @db.Decimal(15, 2)
  icmsStAmount  Decimal? @db.Decimal(15, 2)
  icmsOwnAmount Decimal? @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// PRODUCT INVENTORY
//////////////////////////////////////////////////////

model ProductInventory {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  quantity Int  @default(0)
  minStock Int?
  maxStock Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([productId, warehouseId])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// STOCK MOVEMENT
//////////////////////////////////////////////////////

model StockMovement {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type        MovementType
  quantity    Int
  unitCost    Decimal? @db.Decimal(15, 2)
  reason      String
  documentRef String?
  description String?

  createdAt DateTime @default(now())

  @@unique([companyId, cod])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// SALES (PEDIDOS DE VENDA)
//////////////////////////////////////////////////////

model Sale {
  id        String     @id @default(uuid())
  cod       Int
  companyId String
  company   Company    @relation(fields: [companyId], references: [id])
  clientId  String
  client    Client     @relation(fields: [clientId], references: [id])
  status     SaleStatus @relation(fields: [statusId], references: [id])
  statusId   String

  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation("SalePaymentMethod", fields: [paymentMethodId], references: [id])
  subtotal      Decimal @db.Decimal(15, 2)
  discount      Decimal @default(0) @db.Decimal(15, 2)
  freight       Decimal @default(0) @db.Decimal(15, 2)
  total         Decimal @db.Decimal(15, 2)

  items SaleItem[]
  financialRecords FinancialRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@index([companyId])
}

model SaleItem {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int
  unitPrice Decimal @db.Decimal(15, 2)
  discount  Decimal @default(0) @db.Decimal(15, 2)
  total     Decimal @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@index([companyId])
  @@index([saleId])
}

model SaleStatus {
  id          String      @id @default(uuid())
  cod         Int
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  name        String
  color       String
  stockAction StockAction @default(NONE)

  sales Sale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// FINANCIAL MODULE
//////////////////////////////////////////////////////

model BankAccount {
  id             String   @id @default(uuid())
  cod            Int
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  name           String
  initialBalance Decimal  @default(0) @db.Decimal(15, 2)
  currentBalance Decimal  @default(0) @db.Decimal(15, 2)
  status         Status   @default(ACTIVE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  paymentMethods   PaymentMethod[]
  financialRecords FinancialRecord[]
  transactions     BankTransaction[]

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

model PaymentMethod {
  id                   String       @id @default(uuid())
  cod                  Int
  companyId            String
  company              Company      @relation(fields: [companyId], references: [id])
  name                 String
  destinationAccountId String?
  destinationAccount   BankAccount? @relation(fields: [destinationAccountId], references: [id])
  feePercentage        Decimal      @default(0) @db.Decimal(5, 2)
  isImmediate          Boolean      @default(true)
  status               Status       @default(ACTIVE)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  financialRecords FinancialRecord[]
  sales            Sale[]            @relation("SalePaymentMethod")

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

model FinancialCategory {
  id        String       @id @default(uuid())
  cod       Int
  companyId String
  company   Company      @relation(fields: [companyId], references: [id])
  name      String
  type      CategoryType
  status    Status       @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime @updatedAt

  financialRecords FinancialRecord[]

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

model FinancialRecord {
  id           String              @id @default(uuid())
  cod          Int
  companyId    String
  company      Company             @relation(fields: [companyId], references: [id])
  type         FinancialRecordType
  description  String
  amount       Decimal             @db.Decimal(15, 2)
  dueDate      DateTime
  paymentDate  DateTime?
  status       FinancialStatus     @default(PENDING)
  
  bankAccountId String?
  bankAccount   BankAccount?       @relation(fields: [bankAccountId], references: [id])
  
  paymentMethodId String?
  paymentMethod   PaymentMethod?   @relation(fields: [paymentMethodId], references: [id])
  
  categoryId String?
  category   FinancialCategory? @relation(fields: [categoryId], references: [id])
  
  saleId String?
  sale   Sale? @relation(fields: [saleId], references: [id])
  
  purchaseId String? 
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions BankTransaction[]

  @@unique([companyId, cod])
  @@index([companyId])
  @@index([saleId])
  @@index([status])
}

model BankTransaction {
  id                String          @id @default(uuid())
  companyId         String
  bankAccountId     String
  bankAccount       BankAccount     @relation(fields: [bankAccountId], references: [id])
  financialRecordId String?
  financialRecord   FinancialRecord? @relation(fields: [financialRecordId], references: [id])
  type              TransactionType
  amount            Decimal         @db.Decimal(15, 2)
  date              DateTime        @default(now())
  description       String
  balanceAfter      Decimal         @db.Decimal(15, 2)

  @@index([bankAccountId])
  @@index([date])
}
