generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Status {
  ACTIVE
  INACTIVE
}

enum StockAction {
  NONE
  RESERVE
  COMMIT
}

enum Role {
  ADMIN
  USER
}

enum ClientType {
  PF
  PJ
  PE
}

enum MovementType {
  IN
  OUT
  BALANCE
  RESERVE
  RELEASE_RESERVE
}

enum FinancialRecordType {
  PAYABLE
  RECEIVABLE
}

enum FinancialStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum CategoryType {
  REVENUE
  EXPENSE
}

/// Onde o valor da venda/título deve ser registrado ao usar esta forma de pagamento
enum PaymentValueDestination {
  RECEIVABLE_ONLY // Apenas contas a receber (sem conta bancária vinculada)
  BANK_ACCOUNT    // Conta bancária cadastrada (destinationAccountId)
}

enum NfeAmbiente {
  homologacao
  producao
}

enum NfeStatus {
  PENDENTE
  PROCESSANDO
  AUTORIZADO
  ERRO
  CANCELADO
}

//////////////////////////////////////////////////////
// USER & AUTH
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies      UserCompany[]
  refreshTokens  RefreshToken[]
  stockMovements StockMovement[]
  budgetsSold    Budget[]        @relation("BudgetSeller")
  budgetHistory  BudgetHistory[]
}

model Company {
  id        String   @id @default(uuid())
  cod       Int      @unique
  name      String
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sequence CompanySequence?

  users          UserCompany[]
  clients        Client[]
  suppliers      Supplier[]
  brands         Brand[]
  categories     Category[]
  tags           Tag[]
  products       Product[]
  warehouses     Warehouse[]
  inventories    ProductInventory[]
  taxes          ProductTax[]
  stockMovements StockMovement[]
  sales          Sale[]
  saleStatuses   SaleStatus[]
  budgets        Budget[]

  bankAccounts        BankAccount[]
  paymentMethods      PaymentMethod[]
  financialCategories FinancialCategory[]
  financialRecords    FinancialRecord[]

  // Receipt & Profile Info
  legalName    String? // Razão social (name = nome fantasia)
  logo         String? // Logo em data URL (base64) para cabeçalho de PDFs
  document     String?
  phone        String?
  email        String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?

  // Dados fiscais (emissão de NFe)
  ie               String? // Inscrição estadual
  regimeTributario Int? // 1=Simples Nacional; 2=Simples c/ Excesso; 3=Regime Normal; 4=MEI
  cnae             String?

  nfeConfig NfeConfig?
  nfeEmissions NfeEmission[]

  // LEGACY (1ª versão, mantida para consistência com produção — não usada pelo código atual)
  asaasConfig        AsaasConfig?
  asaasSubscriptions AsaasSubscription[]
  asaasCharges       AsaasCharge[]

  // Billing da plataforma (mensalidade do SaaS paga por este tenant)
  asaasCustomerId      String? // cus_... no Asaas do dono da plataforma
  platformSubscription PlatformSubscription?
  platformCharges      PlatformCharge[]
}

model CompanySequence {
  companyId String  @id
  company   Company @relation(fields: [companyId], references: [id])

  clientSeq        Int @default(0)
  supplierSeq      Int @default(0)
  brandSeq         Int @default(0)
  categorySeq      Int @default(0)
  tagSeq           Int @default(0)
  warehouseSeq     Int @default(0)
  productSeq       Int @default(0)
  productTaxSeq    Int @default(0)
  inventorySeq     Int @default(0)
  stockMovementSeq Int @default(0)
  saleSeq          Int @default(0)
  saleItemSeq      Int @default(0)
  saleStatusSeq    Int @default(0)
  budgetSeq        Int @default(0)
  budgetItemSeq    Int @default(0)
  nfeEmissionSeq   Int @default(0)

  accountSeq           Int @default(0)
  paymentMethodSeq     Int @default(0)
  financialCategorySeq Int @default(0)
  financialRecordSeq   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserCompany {
  userId    String
  companyId String
  role      Role   @default(ADMIN)

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@id([userId, companyId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// CLIENT
//////////////////////////////////////////////////////

model Client {
  id       String     @id @default(uuid())
  cod      Int
  name     String
  type     ClientType
  document String
  status   Status     @default(ACTIVE)

  ie          String?
  indicatorIE Int?

  email String?
  phone String?

  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  country      String  @default("1058")

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // LEGACY (1ª versão, mantida para consistência com produção)
  asaasCustomerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales Sale[]
  budgets Budget[]
  saleCheques Sale[] @relation("SaleChequeCustomer")
  cheques FinancialRecord[] @relation("ChequeCustomer")
  financialRecords FinancialRecord[] @relation("FinancialClient")
  asaasSubscriptions AsaasSubscription[]
  asaasCharges       AsaasCharge[]

  @@unique([companyId, cod])
  @@unique([companyId, document])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// SUPPLIER
//////////////////////////////////////////////////////

model Supplier {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name     String
  document String?
  email    String?
  phone    String?

  products Product[]
  financialRecords FinancialRecord[] @relation("FinancialSupplier")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// BRAND
//////////////////////////////////////////////////////

model Brand {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name     String
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// CATEGORY
//////////////////////////////////////////////////////

model Category {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name String

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// TAG
//////////////////////////////////////////////////////

model Tag {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name String

  products Product[] @relation("ProductTags")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// WAREHOUSE
//////////////////////////////////////////////////////

model Warehouse {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name     String
  location String?

  inventories    ProductInventory[]
  stockMovements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// PRODUCT
//////////////////////////////////////////////////////

model Product {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code             String?
  description      String
  shortDescription String?
  status           Status  @default(ACTIVE)

  price         Decimal  @db.Decimal(15, 2)
  costPrice     Decimal? @db.Decimal(15, 2)
  averageCost   Decimal  @default(0) @db.Decimal(15, 2)

  unit String @default("UN") // Unidade comercial (UN, CX, KG...) usada na NFe

  physicalStock Int      @default(0)
  reservedStock Int      @default(0)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  tags Tag[] @relation("ProductTags")

  inventories    ProductInventory[]
  stockMovements StockMovement[]
  tax            ProductTax?

  weight Decimal? @db.Decimal(15, 3)
  width  Decimal? @db.Decimal(15, 2)
  height Decimal? @db.Decimal(15, 2)
  depth  Decimal? @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItems   SaleItem[]
  budgetItems BudgetItem[]

  @@unique([companyId, cod])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// PRODUCT TAX
//////////////////////////////////////////////////////

model ProductTax {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  productId String  @unique
  product   Product @relation(fields: [productId], references: [id])

  origin      String?
  ncm         String?
  cest        String?
  gtin        String?
  ipiTaxClass String?

  icmsStBase    Decimal? @db.Decimal(15, 2)
  icmsStAmount  Decimal? @db.Decimal(15, 2)
  icmsOwnAmount Decimal? @db.Decimal(15, 2)

  // Dados fiscais para emissão de NFe
  cfop             String? // CFOP padrão para venda (ex: 5102)
  icmsCst          String? // CST/CSOSN do ICMS (ex: 41, 102)
  icmsAliquota     Decimal? @db.Decimal(5, 2)
  pisCst           String? // CST do PIS (ex: 07)
  pisAliquota      Decimal? @db.Decimal(5, 2)
  cofinsCst        String? // CST do COFINS (ex: 07)
  cofinsAliquota   Decimal? @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// PRODUCT INVENTORY
//////////////////////////////////////////////////////

model ProductInventory {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  quantity Int  @default(0)
  minStock Int?
  maxStock Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([productId, warehouseId])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// STOCK MOVEMENT
//////////////////////////////////////////////////////

model StockMovement {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type        MovementType
  quantity    Int
  unitCost    Decimal? @db.Decimal(15, 2)
  reason      String
  documentRef String?
  description String?

  createdAt DateTime @default(now())

  @@unique([companyId, cod])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// SALES (PEDIDOS DE VENDA)
//////////////////////////////////////////////////////

model Sale {
  id        String     @id @default(uuid())
  cod       Int
  companyId String
  company   Company    @relation(fields: [companyId], references: [id])
  clientId  String
  client    Client     @relation(fields: [clientId], references: [id])
  status     SaleStatus @relation(fields: [statusId], references: [id])
  statusId   String

  subtotal      Decimal @db.Decimal(15, 2)
  discount      Decimal @default(0) @db.Decimal(15, 2)
  freight       Decimal @default(0) @db.Decimal(15, 2)
  total         Decimal @db.Decimal(15, 2)

  items SaleItem[]
  financialRecords FinancialRecord[]

  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  installmentsData Json? // Armazena as parcelas discriminadas no pedido
  
  // Cheque fields no pedido (para posterior faturamento)
  chequeNumber     String?
  chequeOwner      String?
  chequeDueDate    DateTime?
  chequeCustomerId String?
  chequeCustomer   Client? @relation("SaleChequeCustomer", fields: [chequeCustomerId], references: [id])
  chequeHistory    String?

  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget Budget?

  // Dados fiscais para emissão de NFe
  naturezaOperacao   String? // ex: "Venda de mercadoria"
  finalidadeEmissao  Int     @default(1) // 1=normal, 2=complementar, 3=ajuste, 4=devolução
  tipoDocumento      Int     @default(1) // 0=entrada, 1=saída
  localDestino       Int     @default(1) // 1=interna, 2=interestadual, 3=exterior
  consumidorFinal    Int     @default(1) // 0=não, 1=sim
  presencaComprador  Int     @default(1) // 0-4, 9
  modalidadeFrete    Int     @default(9) // 0=emitente, 1=destinatário, 2=terceiros, 9=sem frete

  nfeEmission NfeEmission?

  @@unique([companyId, cod])
  @@index([companyId])
  // Relatórios e listas de vendas filtram por empresa+período
  @@index([companyId, date])
}

model SaleItem {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int
  unitPrice Decimal @db.Decimal(15, 2)
  discount  Decimal @default(0) @db.Decimal(15, 2)
  total     Decimal @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@index([companyId])
  @@index([saleId])
}

model SaleStatus {
  id          String      @id @default(uuid())
  cod         Int
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  name        String
  color       String
  stockAction StockAction @default(NONE)

  sales Sale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// BUDGETS (ORÇAMENTOS)
//////////////////////////////////////////////////////

enum BudgetStatus {
  DRAFT
  OPEN
  SENT
  NEGOTIATION
  APPROVED
  REJECTED
  CONVERTED
  EXPIRED
}

model Budget {
  id        String       @id @default(uuid())
  cod       Int
  companyId String
  company   Company      @relation(fields: [companyId], references: [id])
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id])
  sellerId  String?
  seller    User?        @relation("BudgetSeller", fields: [sellerId], references: [id])

  status BudgetStatus @default(DRAFT)

  date       DateTime  @default(now())
  validUntil DateTime?

  subtotal Decimal @db.Decimal(15, 2)
  discount Decimal @default(0) @db.Decimal(15, 2)
  freight  Decimal @default(0) @db.Decimal(15, 2)
  total    Decimal @db.Decimal(15, 2)

  notes        String?
  paymentTerms String?

  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  leadOrigin      String?
  competitor      String?
  lossReason      String?
  commercialNotes String?

  convertedSaleId String? @unique
  convertedSale   Sale?   @relation(fields: [convertedSaleId], references: [id])

  sentAt         DateTime?
  lastFollowUpAt DateTime?

  items   BudgetItem[]
  history BudgetHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@index([companyId])
  @@index([clientId])
  @@index([sellerId])
  @@index([status])
  @@index([validUntil])
}

model BudgetItem {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  budgetId  String
  budget    Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int
  unitPrice Decimal @db.Decimal(15, 2)
  discount  Decimal @default(0) @db.Decimal(15, 2)
  total     Decimal @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@index([companyId])
  @@index([budgetId])
}

model BudgetHistory {
  id       String  @id @default(uuid())
  budgetId String
  budget   Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  userId   String?
  user     User?   @relation(fields: [userId], references: [id])

  action  String
  message String

  createdAt DateTime @default(now())

  @@index([budgetId])
}

//////////////////////////////////////////////////////
// FINANCIAL MODULE
//////////////////////////////////////////////////////

model BankAccount {
  id             String   @id @default(uuid())
  cod            Int
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  name           String
  bankName       String?
  /// BANK = conta bancária, CASH = caixa físico (mesmos valores enviados pelo front como `type`)
  accountKind    String   @default("BANK")
  initialBalance Decimal  @default(0) @db.Decimal(15, 2)
  currentBalance Decimal  @default(0) @db.Decimal(15, 2)
  status         Status   @default(ACTIVE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  paymentMethods   PaymentMethod[]
  financialRecords FinancialRecord[]
  transactions     BankTransaction[]
  financialRecordPayments FinancialRecordPayment[]

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

model PaymentMethod {
  id                   String       @id @default(uuid())
  cod                  Int
  companyId            String
  company              Company      @relation(fields: [companyId], references: [id])
  name                 String
  /// Define se o valor fica só em contas a receber ou é vinculado a uma conta bancária
  valueDestination     PaymentValueDestination @default(RECEIVABLE_ONLY)
  destinationAccountId String?
  destinationAccount   BankAccount? @relation(fields: [destinationAccountId], references: [id])
  feePercentage        Decimal      @default(0) @db.Decimal(5, 2)
  isImmediate          Boolean      @default(true)
  installments         Int          @default(1)
  installmentInterval  Int          @default(30)
  status               Status       @default(ACTIVE)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  financialRecords FinancialRecord[]
  sales            Sale[]
  budgets          Budget[]
  financialRecordPayments FinancialRecordPayment[]
  nfeEmissions     NfeEmission[]

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

model FinancialCategory {
  id        String       @id @default(uuid())
  cod       Int
  companyId String
  company   Company      @relation(fields: [companyId], references: [id])
  name      String
  type      CategoryType
  status    Status       @default(ACTIVE)

  parentId    String?
  parent      FinancialCategory?  @relation("FinancialCategoryHierarchy", fields: [parentId], references: [id])
  children    FinancialCategory[] @relation("FinancialCategoryHierarchy")
  isSelectable Boolean             @default(true)
  hierarchyCode String?

  createdAt DateTime     @default(now())
  updatedAt DateTime @updatedAt

  financialRecords FinancialRecord[]

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

model FinancialRecord {
  id           String              @id @default(uuid())
  cod          Int
  companyId    String
  company      Company             @relation(fields: [companyId], references: [id])
  type         FinancialRecordType
  description  String
  amount       Decimal             @db.Decimal(15, 2)
  paidAmount   Decimal             @default(0) @db.Decimal(15, 2)
  dueDate      DateTime
  paymentDate  DateTime?
  status       FinancialStatus     @default(PENDING)
  
  bankAccountId String?
  bankAccount   BankAccount?       @relation(fields: [bankAccountId], references: [id])
  
  paymentMethodId String?
  paymentMethod   PaymentMethod?   @relation(fields: [paymentMethodId], references: [id])
  
  categoryId String?
  category   FinancialCategory? @relation(fields: [categoryId], references: [id])
  
  saleId String?
  sale   Sale? @relation(fields: [saleId], references: [id])
  
  purchaseId String? 

  clientId String?
  client   Client? @relation("FinancialClient", fields: [clientId], references: [id])
  supplierId String?
  supplier   Supplier? @relation("FinancialSupplier", fields: [supplierId], references: [id])

  // Cheque fields
  chequeNumber     String?
  chequeOwner      String?
  chequeDueDate    DateTime?
  chequeCustomerId String?
  chequeCustomer   Client? @relation("ChequeCustomer", fields: [chequeCustomerId], references: [id])
  chequeHistory    String?
  
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions BankTransaction[]
  payments     FinancialRecordPayment[]
  asaasCharge  AsaasCharge?

  @@unique([companyId, cod])
  @@index([companyId])
  @@index([saleId])
  @@index([status])
  // Dashboard e listas financeiras filtram por empresa+tipo/status+vencimento
  @@index([companyId, status, dueDate])
  @@index([companyId, type, dueDate])
}

model FinancialRecordPayment {
  id                String          @id @default(uuid())
  companyId         String
  financialRecordId String
  financialRecord   FinancialRecord @relation(fields: [financialRecordId], references: [id])

  amount          Decimal       @db.Decimal(15, 2)
  paymentDate     DateTime      @default(now())
  bankAccountId   String
  bankAccount     BankAccount   @relation(fields: [bankAccountId], references: [id])
  paymentMethodId String
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  note      String?
  createdAt DateTime @default(now())

  bankTransactions BankTransaction[]

  @@index([companyId])
  @@index([financialRecordId])
  @@index([paymentDate])
}

model BankTransaction {
  id                String          @id @default(uuid())
  companyId         String
  bankAccountId     String
  bankAccount       BankAccount     @relation(fields: [bankAccountId], references: [id])
  financialRecordId String?
  financialRecord   FinancialRecord? @relation(fields: [financialRecordId], references: [id])
  financialRecordPaymentId String?
  financialRecordPayment   FinancialRecordPayment? @relation(fields: [financialRecordPaymentId], references: [id])
  type              TransactionType
  amount            Decimal         @db.Decimal(15, 2)
  date              DateTime        @default(now())
  description       String
  balanceAfter      Decimal         @db.Decimal(15, 2)

  @@index([bankAccountId])
  @@index([date])
  @@index([financialRecordPaymentId])
}

//////////////////////////////////////////////////////
// NFE (EMISSÃO DE NOTA FISCAL ELETRÔNICA - FOCUS NFE)
//////////////////////////////////////////////////////

/// Configuração de integração com a Focus NFe por empresa (1:1 com Company)
model NfeConfig {
  companyId String  @id
  company   Company @relation(fields: [companyId], references: [id])

  ambiente   NfeAmbiente @default(homologacao)
  habilitado Boolean     @default(false)

  focusEmpresaId Int? // id numérico retornado pela Focus NFe (usado para PUT /v2/empresas/{id})

  // Tokens retornados pela Focus NFe ao cadastrar a empresa (armazenados criptografados)
  tokenProducaoEnc     String?
  tokenHomologacaoEnc  String?

  certificadoValidoDe  DateTime?
  certificadoValidoAte DateTime?
  certificadoCnpj      String?

  serieNfeProducao    String @default("1")
  serieNfeHomologacao String @default("1")

  naturezaOperacaoPadrao String @default("Venda de mercadoria")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Histórico de emissão de NFe vinculado a um pedido de venda
model NfeEmission {
  id        String    @id @default(uuid())
  cod       Int
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  saleId    String    @unique
  sale      Sale      @relation(fields: [saleId], references: [id])

  ref    String    @unique // Referência enviada à Focus NFe (imutável após autorizada)
  status NfeStatus @default(PENDENTE)

  // Campos de conferência do rascunho (revisados antes do envio à SEFAZ)
  dataEmissao     DateTime?
  dataSaida       DateTime?
  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  statusSefaz   String?
  mensagemSefaz String?
  chaveNfe      String?
  numero        String?
  serie         String?

  caminhoXml   String?
  caminhoDanfe String?

  erros Json?

  justificativaCancelamento String?
  canceladoEm               DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// ASAAS LEGACY (1ª versão — cobrança por tenant)
// Mantida para consistência com o banco de produção (já migrado).
// Substituída por PLATFORM BILLING abaixo. Não é usada pelo código atual.
//////////////////////////////////////////////////////

enum AsaasEnvironment {
  SANDBOX
  PRODUCTION
}

enum AsaasSubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
}

model AsaasConfig {
  companyId String  @id
  company   Company @relation(fields: [companyId], references: [id])

  environment AsaasEnvironment @default(SANDBOX)
  enabled     Boolean          @default(false)

  apiKeySandboxEnc  String?
  apiKeyProducaoEnc String?

  webhookToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AsaasSubscription {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  asaasSubscriptionId String @unique
  asaasCustomerId     String

  description String
  value       Decimal @db.Decimal(15, 2)
  cycle       String  @default("MONTHLY")
  billingType String  @default("UNDEFINED")
  nextDueDate DateTime

  status AsaasSubscriptionStatus @default(ACTIVE)

  charges AsaasCharge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([clientId])
}

model AsaasCharge {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  subscriptionId String
  subscription   AsaasSubscription @relation(fields: [subscriptionId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  asaasPaymentId String   @unique
  value          Decimal  @db.Decimal(15, 2)
  dueDate        DateTime
  status         String

  financialRecordId String?          @unique
  financialRecord   FinancialRecord? @relation(fields: [financialRecordId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([subscriptionId])
  @@index([clientId])
}

//////////////////////////////////////////////////////
// PLATFORM BILLING (MENSALIDADE DO SAAS VIA ASAAS)
// Conta Asaas única do dono da plataforma. Cada empresa (tenant)
// que usa o ERP tem uma assinatura mensal cobrada nessa conta.
//////////////////////////////////////////////////////

enum PlatformSubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
}

/// Assinatura da mensalidade do SaaS de uma empresa (1:1 com Company)
model PlatformSubscription {
  id        String  @id @default(uuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  asaasCustomerId     String // cus_... (na conta Asaas da plataforma)
  asaasSubscriptionId String @unique // sub_...

  description String
  value       Decimal  @db.Decimal(15, 2)
  cycle       String   @default("MONTHLY")
  billingType String   @default("UNDEFINED")
  nextDueDate DateTime

  status PlatformSubscriptionStatus @default(ACTIVE)

  charges PlatformCharge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Cobrança mensal gerada pela assinatura da plataforma (espelho de cada payment do Asaas)
model PlatformCharge {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  subscriptionId String
  subscription   PlatformSubscription @relation(fields: [subscriptionId], references: [id])

  asaasPaymentId String   @unique // pay_...
  value          Decimal  @db.Decimal(15, 2)
  dueDate        DateTime
  status         String
  paidAt         DateTime?
  invoiceUrl     String? // página de pagamento do Asaas (boleto/Pix/cartão)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([subscriptionId])
}
