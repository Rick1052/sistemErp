generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Status {
  ACTIVE
  INACTIVE
}

enum Role {
  ADMIN
  USER
}

enum ClientType {
  PF
  PJ
  PE
}

enum MovementType {
  IN
  OUT
  BALANCE
  RESERVE
  RELEASE_RESERVE
}

//////////////////////////////////////////////////////
// USER & AUTH
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies      UserCompany[]
  refreshTokens  RefreshToken[]
  stockMovements StockMovement[]
}

model Company {
  id        String   @id @default(uuid())
  cod       Int      @unique
  name      String
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sequence CompanySequence?

  users          UserCompany[]
  clients        Client[]
  suppliers      Supplier[]
  brands         Brand[]
  categories     Category[]
  tags           Tag[]
  products       Product[]
  warehouses     Warehouse[]
  inventories    ProductInventory[]
  taxes          ProductTax[]
  stockMovements StockMovement[]
}

model CompanySequence {
  companyId String  @id
  company   Company @relation(fields: [companyId], references: [id])

  clientSeq        Int @default(0)
  supplierSeq      Int @default(0)
  brandSeq         Int @default(0)
  categorySeq      Int @default(0)
  tagSeq           Int @default(0)
  warehouseSeq     Int @default(0)
  productSeq       Int @default(0)
  productTaxSeq    Int @default(0)
  inventorySeq     Int @default(0)
  stockMovementSeq Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserCompany {
  userId    String
  companyId String
  role      Role   @default(ADMIN)

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@id([userId, companyId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// CLIENT
//////////////////////////////////////////////////////

model Client {
  id       String     @id @default(uuid())
  cod      Int
  name     String
  type     ClientType
  document String
  status   Status     @default(ACTIVE)

  ie          String?
  indicatorIE Int?

  email String?
  phone String?

  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  country      String  @default("1058")

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([companyId, document])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// SUPPLIER
//////////////////////////////////////////////////////

model Supplier {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name     String
  document String?
  email    String?
  phone    String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// BRAND
//////////////////////////////////////////////////////

model Brand {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name     String
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// CATEGORY
//////////////////////////////////////////////////////

model Category {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name String

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// TAG
//////////////////////////////////////////////////////

model Tag {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name String

  products Product[] @relation("ProductTags")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// WAREHOUSE
//////////////////////////////////////////////////////

model Warehouse {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name     String
  location String?

  inventories    ProductInventory[]
  stockMovements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// PRODUCT
//////////////////////////////////////////////////////

model Product {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code             String?
  description      String
  shortDescription String?
  status           Status  @default(ACTIVE)

  price         Decimal  @db.Decimal(15, 2)
  costPrice     Decimal? @db.Decimal(15, 2)
  averageCost   Decimal  @default(0) @db.Decimal(15, 2)

  physicalStock Int      @default(0)
  reservedStock Int      @default(0)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  tags Tag[] @relation("ProductTags")

  inventories    ProductInventory[]
  stockMovements StockMovement[]
  tax            ProductTax?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// PRODUCT TAX
//////////////////////////////////////////////////////

model ProductTax {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  productId String  @unique
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// PRODUCT INVENTORY
//////////////////////////////////////////////////////

model ProductInventory {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  quantity Int  @default(0)
  minStock Int?
  maxStock Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cod])
  @@unique([productId, warehouseId])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// STOCK MOVEMENT
//////////////////////////////////////////////////////

model StockMovement {
  id        String  @id @default(uuid())
  cod       Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type        MovementType
  quantity    Int
  unitCost    Decimal? @db.Decimal(15, 2)
  reason      String
  documentRef String?
  description String?

  createdAt DateTime @default(now())

  @@unique([companyId, cod])
  @@index([companyId])
}
